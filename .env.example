# copia pra .env e preenche
# token: qualquer string forte, ex: openssl rand -hex 32
GPS_TOKEN=troque-isso

# tópico do ntfy.sh pros alertas de radar
# pega em https://ntfy.sh (botão "Get key" ou inventa um nome difícil de adivinhar)
NTFY_TOPIC=meu-topic-secreto

# interface onde o docker vai bindar a porta
# deixa 0.0.0.0 pra testar local, ou coloca o IP do tailscale/VPN pra restringir
BIND_ADDR=0.0.0.0
